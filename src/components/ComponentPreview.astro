---
interface Props {
  label?: string;
}

const { label } = Astro.props;
---
<div class="component-preview">
  {label && <span class="component-preview__label">{label}</span>}
  <div class="component-preview__canvas">
    <slot />
  </div>
</div>

<style>
  .component-preview {
    border: 1px solid var(--color-border-divider-default-7s2wjw, #e9ebed);
    border-radius: 8px;
    margin: 1rem 0;
    overflow: hidden;
  }

  .component-preview__label {
    display: block;
    padding: 8px 16px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--color-text-label-gxskdy, #5f6b7a);
    border-bottom: 1px solid var(--color-border-divider-default-7s2wjw, #e9ebed);
    background: var(--color-background-layout-main-sfhm4y, #ffffff);
  }

  .component-preview__canvas {
    padding: 24px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    background: var(--color-background-layout-main-sfhm4y, #ffffff);
  }

  .component-preview__canvas > :global(*) {
    min-width: 0;
  }

  .component-preview__canvas > :global(cs-grid),
  .component-preview__canvas > :global(cs-radio-group),
  .component-preview__canvas > :global(cs-tiles),
  .component-preview__canvas > :global(cs-space-between),
  .component-preview__canvas > :global(cs-text-content) {
    width: 100%;
  }
</style>
