---
import { marked } from 'marked';

interface Props {
  component: string;
}

const { component } = Astro.props;

let props: Array<{
  name: string;
  type: string;
  description: string;
  required: boolean;
  defaultValue?: string;
}> = [];

try {
  const mod = await import(`../data/props/${component}.json`);
  props = mod.default;
} catch {
  // No props JSON generated yet for this component
}

/** Convert camelCase to kebab-case: "fontSize" → "font-size" */
function toKebab(name: string): string {
  return name.replace(/[A-Z]/g, (m) => `-${m.toLowerCase()}`);
}

const renderedProps = await Promise.all(
  props.map(async (prop) => ({
    ...prop,
    descriptionHtml: await marked.parse(prop.description),
  }))
);
---

{renderedProps.length > 0 && (
  <dl class="props-list">
    {renderedProps.map(prop => (
      <div class="props-entry" id={`prop-${toKebab(prop.name)}`}>
        <dt class="props-header">
          <a class="props-name" href={`#prop-${toKebab(prop.name)}`}>
            <code>{toKebab(prop.name)}</code>
          </a>
          <span class="props-type">
            <code>{prop.type}</code>
          </span>
          {prop.required && (
            <span class="props-badge props-badge--required">required</span>
          )}
          {!prop.required && prop.defaultValue && (
            <span class="props-badge props-badge--default">
              default: <code>{prop.defaultValue}</code>
            </span>
          )}
        </dt>
        <dd class="props-description" set:html={prop.descriptionHtml} />
      </div>
    ))}
  </dl>
)}

<style>
  .props-list {
    margin: 1.5rem 0;
    padding: 0;
    font-size: 14px;
    max-width: 1200px;
  }

  .props-entry {
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border-divider-default-7s2wjw, #e9ebed);
  }

  .props-entry:first-child {
    border-top: 1px solid var(--color-border-divider-default-7s2wjw, #e9ebed);
  }

  .props-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px;
    margin: 0;
    font-weight: 400;
  }

  .props-name code {
    font-family: "SFMono-Regular", "Menlo", "Monaco", "Consolas", monospace;
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text-column-header-p3mvlz, #414d5c);
    background: none;
    padding: 0;
  }

  .props-name {
    text-decoration: none;
    color: inherit;
  }

  .props-name:hover code {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .props-type code {
    font-family: "SFMono-Regular", "Menlo", "Monaco", "Consolas", monospace;
    font-size: 13px;
    color: var(--color-text-column-header-p3mvlz, #5f6b7a);
    background: var(--color-background-code-editor-gutter-default-l9we2o, #f2f3f3);
    padding: 2px 8px;
    border-radius: 4px;
    word-break: break-word;
  }

  .props-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.03em;
    padding: 2px 8px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .props-badge--required {
    background: #fdf3f1;
    color: #d91515;
  }

  .props-badge--default code {
    font-family: "SFMono-Regular", "Menlo", "Monaco", "Consolas", monospace;
    font-size: 11px;
    background: none;
    padding: 0;
  }

  .props-badge--default {
    background: var(--color-background-code-editor-gutter-default-l9we2o, #f2f3f3);
    color: var(--color-text-column-header-p3mvlz, #5f6b7a);
  }

  .props-description {
    margin: 8px 0 0;
    padding: 0;
    line-height: 1.6;
    color: var(--color-text-column-header-p3mvlz, #414d5c);
  }

  .props-description :global(p) {
    margin: 0 0 0.5em;
  }

  .props-description :global(p:last-child) {
    margin-bottom: 0;
  }

  .props-description :global(ul),
  .props-description :global(ol) {
    margin: 0.25em 0 0.5em;
    padding-left: 1.5em;
  }

  .props-description :global(li) {
    margin: 0.15em 0;
  }

  .props-description :global(code) {
    font-family: "SFMono-Regular", "Menlo", "Monaco", "Consolas", monospace;
    font-size: 13px;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--color-background-code-editor-gutter-default-l9we2o, #f2f3f3);
  }

  .props-description :global(pre) {
    margin: 0.5em 0;
    padding: 12px 16px;
    border-radius: 6px;
    background: var(--color-background-code-editor-gutter-default-l9we2o, #f2f3f3);
    overflow-x: auto;
    font-size: 13px;
  }

  .props-description :global(pre code) {
    padding: 0;
    background: none;
  }
</style>
