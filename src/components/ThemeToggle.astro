---
/**
 * Global theme toggle. Matches Cloudscape's half-circle icon.
 * Toggles awsui-dark-mode class on <html> and persists to localStorage.
 */
---
<cs-button
  class="theme-toggle"
  variant="icon"
  aria-label="Mode toggle"
>
  <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" width="16" height="16">
    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5" fill="none"></circle>
    <path d="M8 15C11.866 15 15 11.866 15 8C15 4.13401 11.866 1 8 1V15Z" fill="currentColor"></path>
  </svg>
</cs-button>

<script is:inline>
  if (!window.__themeToggleInit) {
    window.__themeToggleInit = true;
    document.addEventListener('click', (e) => {
      if (e instanceof CustomEvent && e.target.closest('.theme-toggle')) {
        const isDark = document.documentElement.classList.toggle('awsui-dark-mode');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      }
    });
  }
</script>

<style>
  .theme-toggle {
    position: fixed;
    top: 16px;
    right: 16px;
    z-index: 1000;
  }
</style>
