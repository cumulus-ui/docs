---
import '@cumulus-ui/design-tokens/tokens.css';
import { Font } from 'astro:assets';
import { getCollection } from 'astro:content';
import { displayName } from '@/utils/display-name';

interface Props {
  title: string;
  breadcrumbs?: Array<{ text: string; href: string }>;
  activeComponentId?: string;
  disableContentPaddings?: boolean;
}

const { title, breadcrumbs = [], activeComponentId, disableContentPaddings = false } = Astro.props;
const components = (await getCollection('components')).sort((a, b) => a.data.component.localeCompare(b.data.component));

const navItems = components.map(comp => ({
  type: 'link' as const,
  text: displayName(comp.data.component),
  href: `/components/${comp.id}`,
}));
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Cumulus UI</title>
    <script is:inline>
      const theme = localStorage.getItem('theme') ??
        (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      if (theme === 'dark') document.documentElement.classList.add('awsui-dark-mode');
    </script>
    <Font cssVariable="--font-open-sans" preload />
    <script>import '@cumulus-ui/components';</script>
  </head>
  <body>
    <cs-app-layout-toolbar
      id="app-layout"
      tools-hide
      {...disableContentPaddings ? { 'disable-content-paddings': true } : {}}
    >
      <div slot="navigation">
        <cs-side-navigation
          id="side-nav"
        ></cs-side-navigation>
      </div>
      <div slot="breadcrumbs">
        <cs-breadcrumb-group id="breadcrumbs"></cs-breadcrumb-group>
      </div>
      <slot />
    </cs-app-layout-toolbar>

    <cs-button
      class="theme-toggle"
      variant="icon"
      aria-label="Mode toggle"
    >
      <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" width="16" height="16">
        <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5" fill="none"></circle>
        <path d="M8 15C11.866 15 15 11.866 15 8C15 4.13401 11.866 1 8 1V15Z" fill="currentColor"></path>
      </svg>
    </cs-button>

    <script is:inline define:vars={{ navItems, breadcrumbs, activeComponentId }}>
      // Side navigation
      const sideNav = document.getElementById('side-nav');
      if (sideNav) {
        sideNav.header = { text: 'Components', href: '/components' };
        sideNav.items = navItems;
        if (activeComponentId) {
          sideNav.activeHref = '/components/' + activeComponentId;
        }
      }

      // Breadcrumbs
      const bc = document.getElementById('breadcrumbs');
      if (bc && breadcrumbs.length > 0) {
        bc.items = breadcrumbs;
      }

      // Theme toggle
      if (!window.__themeToggleInit) {
        window.__themeToggleInit = true;
        document.addEventListener('click', (e) => {
          if (e instanceof CustomEvent && e.target.closest('.theme-toggle')) {
            const isDark = document.documentElement.classList.toggle('awsui-dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
          }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  body {
    margin: 0;
    font-family: var(--font-open-sans, var(--font-family-base));
    color: var(--color-text-body-default);
  }

  .astro-code {
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13px;
    line-height: 1.5;
  }

  .awsui-dark-mode .astro-code,
  .awsui-dark-mode .astro-code span {
    color: var(--shiki-dark) !important;
    background-color: var(--shiki-dark-bg) !important;
  }

  .theme-toggle {
    position: fixed;
    top: 8px;
    right: 16px;
    z-index: 1000;
  }
</style>
