---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const components = await getCollection('components');
  return components.map(comp => ({
    params: { name: comp.id },
    props: { comp },
  }));
}

const { comp } = Astro.props;
const { Content } = await render(comp);

const breadcrumbs = [
  { text: 'Home', href: '/' },
  { text: 'Components', href: '/' },
  { text: comp.data.title, href: `/components/${comp.id}` },
];
---
<BaseLayout title={comp.data.title} breadcrumbs={breadcrumbs} activeComponentId={comp.id}>
  <cs-content-layout default-padding>
    <cs-header slot="header" variant="h1" description={`${comp.data.description} — <${comp.data.tag}>`}>
      {comp.data.title}
    </cs-header>
    <Content />
  </cs-content-layout>
</BaseLayout>
