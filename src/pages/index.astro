---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const components = (await getCollection('components')).sort((a, b) => a.data.title.localeCompare(b.data.title));
---
<BaseLayout title="Home">
  <main style="max-width: 1200px; margin: 0 auto; padding: 48px 24px;">
    <cs-space-between size="l" direction="vertical">
      <div>
        <cs-box variant="h1">Cumulus UI</cs-box>
        <cs-box variant="p" color="text-body-secondary">
          <a href="https://developer.mozilla.org/en-US/docs/Web/API/Web_components">Web Components</a> inspired by Cloudscape Design System.
          {' '}<cs-badge color="blue">{components.length}</cs-badge>
        </cs-box>
      </div>
      <div class="tiles-grid">
        {components.map(comp => (
          <a href={`/components/${comp.id}`} class="tile">
            <cs-box font-size="body-s" color="text-status-inactive"><code>&lt;{comp.data.tag}&gt;</code></cs-box>
            <cs-box font-size="heading-s" font-weight="bold" color="text-heading-default">{comp.data.title}</cs-box>
            <cs-box font-size="body-s" color="text-body-secondary">{comp.data.description}</cs-box>
          </a>
        ))}
      </div>
    </cs-space-between>
  </main>
</BaseLayout>

<style>
  .tiles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .tile {
    display: block;
    padding: 16px;
    border: var(--border-divider-section-width-4wm2it, 1px) solid var(--color-border-divider-default-7s2wjw, #e9ebed);
    border-radius: var(--border-radius-container-qk5ft4, 16px);
    text-decoration: none;
    background: var(--color-background-container-content-z79u4u, #fff);
  }
  .tile:hover {
    border-color: var(--color-text-link-default-enwvrt, #006ce0);
  }
</style>
